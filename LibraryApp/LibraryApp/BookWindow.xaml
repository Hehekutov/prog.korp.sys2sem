<Window x:Class="LibraryApp.BookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга" Height="320" Width="420" WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <Label>Название</Label>
            <TextBox x:Name="TitleBox" />

            <Label>Автор</Label>
            <ComboBox x:Name="AuthorBox" DisplayMemberPath="LastName" />

            <Label>Жанр</Label>
            <ComboBox x:Name="GenreBox" DisplayMemberPath="Name" />

            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                <StackPanel Width="150">
                    <Label>Год</Label>
                    <TextBox x:Name="YearBox" />
                </StackPanel>

                <StackPanel Margin="10,0,0,0">
                    <Label>ISBN</Label>
                    <TextBox x:Name="IsbnBox" Width="200" />
                </StackPanel>
            </StackPanel>

            <Label>В наличии (шт)</Label>
            <TextBox x:Name="QuantityBox" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="OkButton" Content="OK" Width="80" Margin="5" IsDefault="True" />
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Margin="5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
